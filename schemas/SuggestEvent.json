{
  "$defs": {
    "AbortReason": {
      "description": "Cancellation causes.",
      "oneOf": [
        {
          "const": "superseded",
          "description": "A newer request arrived on the same slot.",
          "type": "string"
        },
        {
          "const": "session_closed",
          "description": "The session was deleted mid-generation.",
          "type": "string"
        },
        {
          "const": "shutdown",
          "description": "The hub is shutting down.",
          "type": "string"
        },
        {
          "const": "unknown",
          "description": "Reason added by a newer hub.",
          "type": "string"
        }
      ]
    },
    "SuggestAborted": {
      "description": "Why a generation ended without a final list.",
      "properties": {
        "reason": {
          "$ref": "#/$defs/AbortReason",
          "description": "Cancellation cause."
        }
      },
      "required": [
        "reason"
      ],
      "type": "object"
    },
    "SuggestDelta": {
      "description": "Incremental suggestion text.",
      "properties": {
        "i": {
          "description": "Suggestion index, `0 ≤ i < n`.",
          "format": "uint8",
          "maximum": 255,
          "minimum": 0,
          "type": "integer"
        },
        "text": {
          "description": "Text fragment to append.",
          "type": "string"
        }
      },
      "required": [
        "i",
        "text"
      ],
      "type": "object"
    },
    "SuggestFinal": {
      "description": "Final suggestion list.",
      "properties": {
        "suggestions": {
          "description": "Post-processed suggestions, best first. May be shorter than `n`\n(an empty slot costs less than a bad suggestion, SPEC §7.A).",
          "items": {
            "$ref": "#/$defs/Suggestion"
          },
          "type": "array"
        }
      },
      "required": [
        "suggestions"
      ],
      "type": "object"
    },
    "Suggestion": {
      "description": "One suggestion.",
      "properties": {
        "origin": {
          "anyOf": [
            {
              "$ref": "#/$defs/SuggestionOrigin"
            },
            {
              "type": "null"
            }
          ],
          "description": "Where it came from — memory-sourced suggestions carry a discreet\nmarker in the UI (SPEC §5.B)."
        },
        "score": {
          "description": "Model confidence, higher is better (comparable within one response\nonly).",
          "format": "double",
          "type": "number"
        },
        "text": {
          "description": "Suggested text. **P0 content** — never logged.",
          "type": "string"
        }
      },
      "required": [
        "text",
        "score"
      ],
      "type": "object"
    },
    "SuggestionOrigin": {
      "description": "Origin of a suggestion.",
      "oneOf": [
        {
          "const": "model",
          "description": "Generated by the language model.",
          "type": "string"
        },
        {
          "const": "memory",
          "description": "Short-circuited from a recurring phrase in personal memory\n(no LLM call — SPEC §5.B).",
          "type": "string"
        },
        {
          "const": "ngram",
          "description": "Produced by the embedded n-gram fallback (LLM down, SPEC §2.C).",
          "type": "string"
        },
        {
          "const": "unknown",
          "description": "Origin added by a newer hub.",
          "type": "string"
        }
      ]
    }
  },
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "description": "Events of the `/suggest` SSE stream (SPEC §5.A).\n\nSSE mapping: the variant name is the SSE `event:` field, the payload is\nthe `data:` JSON. The canonical JSON form below (`{\"event\": …, \"data\":\n…}`) is what the schema documents.\n\n`non_exhaustive`: streams may gain event kinds; clients ignore unknown\nevents.",
  "oneOf": [
    {
      "description": "Incremental text for suggestion `i` (append to previous deltas).",
      "properties": {
        "data": {
          "$ref": "#/$defs/SuggestDelta"
        },
        "event": {
          "const": "delta",
          "type": "string"
        }
      },
      "required": [
        "event",
        "data"
      ],
      "type": "object"
    },
    {
      "description": "Terminal event: the complete, post-processed suggestion list.",
      "properties": {
        "data": {
          "$ref": "#/$defs/SuggestFinal"
        },
        "event": {
          "const": "final",
          "type": "string"
        }
      },
      "required": [
        "event",
        "data"
      ],
      "type": "object"
    },
    {
      "description": "Terminal event: generation was cancelled.",
      "properties": {
        "data": {
          "$ref": "#/$defs/SuggestAborted"
        },
        "event": {
          "const": "aborted",
          "type": "string"
        }
      },
      "required": [
        "event",
        "data"
      ],
      "type": "object"
    }
  ],
  "title": "SuggestEvent"
}
